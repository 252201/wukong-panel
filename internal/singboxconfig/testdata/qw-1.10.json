{
  "log": { "level": "warn", "timestamp": true },
  "inbounds": [
    {
      "type": "hysteria2",
      "tag": "hy2-v6-in",
      "listen": "::",
      "listen_port": 55119,
      "sniff": true,
      "sniff_override_destination": true,
      "users": [{ "name": "sample", "password": "redacted-test-secret" }],
      "ignore_client_bandwidth": true,
      "tls": { "enabled": true, "certificate_path": "/tmp/test.cer", "key_path": "/tmp/test.key" }
    }
  ],
  "outbounds": [
    { "type": "direct", "tag": "out-vpngate", "bind_interface": "tun0", "domain_strategy": "prefer_ipv6" },
    { "type": "direct", "tag": "out-vpngate-v4only", "bind_interface": "tun0", "domain_strategy": "ipv4_only" },
    { "type": "block", "tag": "block" }
  ],
  "route": {
    "rules": [
      { "network": "udp", "port": 443, "outbound": "block" },
      { "domain_suffix": ["example.com"], "outbound": "out-vpngate-v4only" }
    ],
    "final": "out-vpngate"
  }
}
